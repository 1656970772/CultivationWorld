  {
    "id": "need_npc_cultivation",
    "name": "修炼",
    "selectStrategy": "greedy",
    "description": "提升境界修为，是修士本业。突破当前境界有两条硬门槛（见 npc-lifecycle.tryBreakthrough）：①totalCultivation 达到 nextCultivationRequired，且 cultivation 达到根基比例；②真气 qi 达到下一境界 qiRequired。修炼需求会判断当前境界还差什么：缺真气(qiBelowNextRank=true)→A* 推导『闭关产气 / 兑换→服用聚气丹』补真气；缺数值修为(cultivationShortfall>0 或 cultivationRootShortfall>0)→『闭关推进 cultivation / 外出游历攒 experienceCultivation』补修为。贡献充足时赴修炼场加速，不足时推导『接→做→交任务攒贡献』经济链。",
    "basePriority": 30,
    "evaluatorType": "configurable",
    "evaluatorConfig": {
      "basePriority": 30,
      "rules": [
        { "_comment": "缺总修为：推动闭关/游历补数值修为。", "condition": { "key": "cultivationShortfall", "op": "gt", "value": 0 }, "priorityBoost": 20, "urgencyBoost": 10 },
        { "_comment": "缺根基修为：推动闭关修炼补 cultivation。", "condition": { "key": "cultivationRootShortfall", "op": "gt", "value": 0 }, "priorityBoost": 10, "urgencyBoost": 8 },
        { "_comment": "缺真气：当前境界真气未达下一境界门槛，推动闭关产气/聚气丹补真气。", "condition": { "key": "qiBelowNextRank", "op": "eq", "value": true }, "priorityBoost": 15, "urgencyBoost": 10 },
        { "condition": { "key": "factionAtPeace", "op": "eq", "value": true }, "priorityBoost": 10, "urgencyBoost": 5 }
      ],
      "satisfiedCondition": null
    },
    "goalState": {
      "_comment": "增量式目标：totalCultivation 每次只要求当前值 + nextCultivationRequired 的 1%，并夹到 nextCultivationRequired。做完重评估，下轮再推进；qiBelowNextRank=false 与数值修为同为突破硬门槛。",
      "totalCultivation": { "op": "gte", "incrementOf": "totalCultivation", "stepRatioOf": "nextCultivationRequired", "stepRatio": 0.01, "maxOf": "nextCultivationRequired" },
      "qiBelowNextRank": { "op": "eq", "value": false }
    }
  },
